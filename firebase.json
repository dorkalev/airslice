{
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "emulators": {
    "storage": { "port": 9199 },
    "auth": { "port": 9099 },
    "ui": { "enabled": false }
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/admin", "destination": "/admin.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|mjs)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
      }
    ]
  }
}
