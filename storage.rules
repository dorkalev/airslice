rules_version = '2';

// AIRSLICE public wall. Anyone may watch runs. Uploads require an (anonymous)
// signed-in user, must be a reasonably-sized video, and are stamped with the
// uploader's uid as `owner` — only that uid can delete. Players consent
// explicitly in the game UI before upload.
//
// This limits what a single request can do, but rules cannot rate-limit across
// requests. Enable Firebase App Check enforcement on Storage (see
// leaderboard.js APPCHECK_SITE_KEY) to keep scripted/bot uploads out, and set a
// GCP budget alert as a backstop.
service firebase.storage {
  match /b/{bucket}/o {
    // Site owner — may moderate (delete) any run. Signs in with this Google
    // account on admin.html.
    function isAdmin() {
      return request.auth.token.email == 'YOUR_ADMIN_EMAIL@example.com'
          && request.auth.token.email_verified == true;
    }
    match /runs/{file} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.size < 25 * 1024 * 1024
                    && request.resource.contentType.matches('video/(webm|mp4)(;.*)?')
                    && request.resource.metadata.owner == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.metadata.owner == request.auth.uid
                        || isAdmin());
      allow update: if false;
    }
    // Tiny JPEG thumbnails shown instantly on the wall (full video loads on
    // interaction). Public read; small images only.
    match /posters/{file} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.size < 400 * 1024
                    && request.resource.contentType == 'image/jpeg'
                    && request.resource.metadata.owner == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.metadata.owner == request.auth.uid || isAdmin());
      allow update: if false;
    }
    // Tiny animated preview loops autoplayed on the wall. Public read; small.
    match /previews/{file} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.size < 1024 * 1024
                    && request.resource.contentType.matches('video/(webm|mp4)(;.*)?')
                    && request.resource.metadata.owner == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.metadata.owner == request.auth.uid || isAdmin());
      allow update: if false;
    }
    // Archived (hidden) runs — admin-only. Not listed on the public wall.
    match /archived/{file} {
      allow read, write: if isAdmin();
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
